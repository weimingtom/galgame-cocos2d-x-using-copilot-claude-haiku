# GalGame Script Example
# Format: command|param1:value1|param2:value2

# Show background
background|path:assets/bg_school.png

# Show character
show_character|name:Alice|position:left
show_character|name:Bob|position:right

# Dialogue
dialogue|character:Alice|text:Hello, nice to meet you!
dialogue|character:Bob|text:Hi Alice! How are you?
dialogue|character:Alice|text:I'm doing great, thanks for asking!

# Hide character
hide_character|name:Bob

# Scene transition
background|path:assets/bg_park.png
dialogue|character:Alice|text:Let's go to the park!
